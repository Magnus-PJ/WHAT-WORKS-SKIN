{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "number": {
      "type": "string",
      "minLength": 1
    },
    "filed": {
      "type": "string",
      "minLength": 1
    },
    "eyebrowKicker": {
      "type": "string",
      "minLength": 1
    },
    "tier": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "featured": {
      "type": "boolean"
    },
    "headlineSize": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "chemistry": {
      "type": "string"
    },
    "tagline": {
      "type": "object",
      "properties": {
        "italic": {
          "type": "string"
        },
        "rest": {
          "type": "string"
        }
      },
      "required": [
        "italic",
        "rest"
      ],
      "additionalProperties": false
    },
    "lead": {
      "type": "string",
      "minLength": 1
    },
    "atGlance": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          {
            "type": "string"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "toc": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
          {
            "type": "string"
          },
          {
            "type": "string"
          }
        ]
      }
    },
    "whatItIs": {
      "type": "object",
      "properties": {
        "dropCap": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1
        },
        "title": {
          "type": "object",
          "properties": {
            "plain": {
              "type": "string"
            },
            "italic": {
              "type": "string"
            }
          },
          "required": [
            "plain",
            "italic"
          ],
          "additionalProperties": false
        },
        "body": {
          "type": "string",
          "minLength": 1
        },
        "body2": {
          "type": "string"
        }
      },
      "required": [
        "dropCap",
        "title",
        "body"
      ],
      "additionalProperties": false
    },
    "mechanism": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "k": {
            "type": "string"
          },
          "b": {
            "type": "string"
          }
        },
        "required": [
          "k",
          "b"
        ],
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "c": {
            "type": "string"
          },
          "n": {
            "type": "string"
          },
          "w": {
            "type": "string",
            "pattern": "^(?:100|[1-9]?\\d)%$"
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "c",
          "n",
          "w",
          "note"
        ],
        "additionalProperties": false
      }
    },
    "studies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "authors": {
            "type": "string"
          },
          "journal": {
            "type": "string"
          },
          "year": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "string"
              }
            ]
          },
          "pmid": {
            "type": "string"
          },
          "n": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              {
                "type": "null"
              }
            ]
          },
          "design": {
            "type": "string"
          },
          "duration": {
            "type": "string"
          },
          "finding": {
            "type": "string"
          },
          "grade": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          }
        },
        "required": [
          "authors",
          "journal",
          "year",
          "pmid",
          "design",
          "duration",
          "finding",
          "grade"
        ],
        "additionalProperties": false
      }
    },
    "concentration": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "c": {
            "type": "string"
          },
          "v": {
            "type": "string"
          },
          "b": {
            "type": "string"
          }
        },
        "required": [
          "c",
          "v",
          "b"
        ],
        "additionalProperties": false
      }
    },
    "byConcern": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "concern": {
            "type": "string"
          },
          "range": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        },
        "required": [
          "concern",
          "range",
          "note",
          "evidence"
        ],
        "additionalProperties": false
      }
    },
    "howToUse": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "eyebrow": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "required": [
          "eyebrow",
          "body"
        ],
        "additionalProperties": false
      }
    },
    "mistakes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "t": {
            "type": "string"
          },
          "b": {
            "type": "string"
          }
        },
        "required": [
          "t",
          "b"
        ],
        "additionalProperties": false
      }
    },
    "myths": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "m": {
            "type": "string"
          },
          "t": {
            "type": "string"
          }
        },
        "required": [
          "m",
          "t"
        ],
        "additionalProperties": false
      }
    },
    "pairings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "with": {
            "type": "string"
          },
          "verdict": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "with",
          "verdict",
          "note",
          "ok"
        ],
        "additionalProperties": false
      }
    },
    "products": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "brand": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "price": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "brand",
          "name",
          "tier",
          "note"
        ],
        "additionalProperties": false
      }
    },
    "faq": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "q": {
            "type": "string"
          },
          "a": {
            "type": "string"
          }
        },
        "required": [
          "q",
          "a"
        ],
        "additionalProperties": false
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tier": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          },
          "name": {
            "type": "string"
          },
          "sub": {
            "type": "string"
          }
        },
        "required": [
          "tier",
          "name",
          "sub"
        ],
        "additionalProperties": false
      }
    },
    "relatedIngredients": {
      "minItems": 2,
      "maxItems": 4,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "properties": {
              "slug": {
                "type": "string",
                "minLength": 1
              },
              "sub": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "slug",
              "sub"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "reviewer": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "credentials": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "quote": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "title"
      ],
      "additionalProperties": false
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "slug",
    "name",
    "number",
    "filed",
    "eyebrowKicker",
    "tier",
    "lead",
    "atGlance",
    "toc",
    "whatItIs",
    "products",
    "faq"
  ],
  "additionalProperties": false
}