{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "methodology": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+$"
        },
        "lastUpdated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "changelog": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "v": {
                "type": "string",
                "pattern": "^v\\d+\\.\\d+$"
              },
              "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "v",
              "date",
              "note"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "version",
        "lastUpdated",
        "changelog"
      ],
      "additionalProperties": false
    },
    "pages": {
      "type": "object",
      "properties": {
        "methodology": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "howWeRate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "sources": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "corrections": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "editors": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "letters": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "required": [
        "methodology",
        "howWeRate",
        "sources",
        "corrections",
        "editors",
        "letters"
      ],
      "additionalProperties": false
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "methodology",
    "pages"
  ],
  "additionalProperties": false
}