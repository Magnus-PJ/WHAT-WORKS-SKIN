{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "slug": {
      "type": "string",
      "minLength": 1
    },
    "n": {
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "date": {
      "type": "string",
      "minLength": 1
    },
    "year": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "headline": {
      "type": "string",
      "minLength": 1
    },
    "dek": {
      "type": "string",
      "minLength": 1
    },
    "signed": {
      "type": "string"
    },
    "pageRef": {
      "type": "string"
    },
    "eyebrow": {
      "type": "string"
    },
    "verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "n": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "verdict": {
            "type": "string"
          },
          "tier": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D"
            ]
          },
          "body": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "text": {
                          "type": "string",
                          "minLength": 1
                        },
                        "kind": {
                          "type": "string",
                          "enum": [
                            "ingredient",
                            "concern",
                            "product",
                            "supplement",
                            "routine"
                          ]
                        },
                        "slug": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "text",
                        "kind",
                        "slug"
                      ]
                    }
                  ]
                }
              }
            ]
          },
          "bottom": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "verdict"
        ],
        "additionalProperties": {}
      }
    },
    "focus": {
      "type": "object",
      "properties": {
        "concern": {
          "type": "string",
          "minLength": 1
        },
        "product": {
          "type": "string",
          "minLength": 1
        },
        "supplement": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "slug",
    "n",
    "date",
    "year",
    "headline",
    "dek"
  ]
}