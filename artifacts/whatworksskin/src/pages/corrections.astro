</style>

<script>
  // Progressive enhancement: the form falls back to a no-op if JS is
  // disabled (the API endpoint expects JSON, not multipart, so we
  // intentionally don't render a `method=POST action=...` for the
  // legacy path — the mailto in the footer is the JS-off escape
  // hatch). With JS, we POST the JSON body to the api-server, surface
  // validation errors inline, and replace the form with a confirmation
  // card that re-states the SLAs from the policy above.
  (() => {
    const form = document.getElementById("corrections-form") as HTMLFormElement | null;
    const status = document.getElementById("cf-status") as HTMLElement | null;
    if (!form || !status) return;

    // Prefill the page URL with the current location so a reader who
    // clicked the footer CTA from a brief page doesn't have to copy
    // it. The `?page=` hint takes precedence so the brief-page CTA
    // can deep-link to the form with the URL already filled in.
    const params = new URLSearchParams(window.location.search);
    const pageInput = form.elements.namedItem("pageUrl") as HTMLInputElement | null;
    if (pageInput && pageInput.value === "") {
      pageInput.value = params.get("page") ?? window.location.href;
    }

    // Inject the confirmation card once so the post-submit DOM is
    // ready to swap in without a re-render. Hidden via CSS until
    // the form acquires the `.done` class.
    const done = document.createElement("div");
    done.className = "done-card";
    done.innerHTML = `
      <h3 class="done-h">Got it. Filed for review.</h3>
      <p class="done-sub">One of the editors will pick it up. Per the policy:</p>
      <ul class="done-sla">
        <li><strong>TYPO</strong> acknowledged within 24h.</li>
        <li><strong>FACTUAL</strong> resolved within 7 days.</li>
        <li><strong>INTERPRETIVE</strong> re-graded in the next Trend Watch.</li>
      </ul>
    `;
    form.appendChild(done);

    function setStatus(msg: string, kind: "ok" | "err" | "" = "") {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove("ok", "err");
      if (kind) status.classList.add(kind);
    }

    form.addEventListener("submit", async (evt) => {
      evt.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const fd = new FormData(form);
      const payload = {
        pageUrl: String(fd.get("pageUrl") ?? "").trim(),
        description: String(fd.get("description") ?? "").trim(),
        evidenceUrl: String(fd.get("evidenceUrl") ?? "").trim() || undefined,
        email: String(fd.get("email") ?? "").trim() || undefined,
        website: String(fd.get("website") ?? ""),
      };
      const btn = form.querySelector(".submit-btn") as HTMLButtonElement | null;
      if (btn) btn.disabled = true;
      setStatus("Sending…");
      try {
        const res = await fetch("/api/corrections", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
          credentials: "omit",
        });
        if (res.status === 204) {
          form.classList.add("done");
          setStatus("");
        } else if (res.status === 429) {
          setStatus("You've hit the per-hour limit on this network. Try again later or email editorial@whatworksskin.com.", "err");
          if (btn) btn.disabled = false;
        } else if (res.status === 400) {
          setStatus("That payload didn't validate. Check the URL and description and try again.", "err");
          if (btn) btn.disabled = false;
        } else {
          setStatus("Something went wrong on our side. Email editorial@whatworksskin.com if it persists.", "err");
          if (btn) btn.disabled = false;
        }
      } catch (err) {
        console.warn("corrections form: network error", err);
        setStatus("Couldn't reach the server. Check your connection or email editorial@whatworksskin.com.", "err");
        if (btn) btn.disabled = false;
      }
    });
  })();
</script>
