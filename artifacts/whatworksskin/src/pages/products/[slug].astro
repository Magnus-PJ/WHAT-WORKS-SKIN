---
import { getCollection, getEntry } from "astro:content";
import Base from "@/layouts/Base.astro";
import ProductBrief from "@/components/ProductBrief.astro";

export async function getStaticPaths() {
  const products = await getCollection("products");
  return products.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { id: entry.id },
  }));
}

const { id } = Astro.props;
const entry = await getEntry("products", id);
if (!entry) {
  throw new Error(`Product not found: ${id}`);
}
const data = entry.data;
const description = `${data.brand} ${data.name} — ${data.hero ?? ""}`.slice(0, 180);

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": data.name,
  "image": Astro.site ? `${Astro.site.toString().replace(/\/$/, "")}/opengraph.jpg` : "https://whatworksskin.com/opengraph.jpg",
  "description": description,
  "brand": {
    "@type": "Brand",
    "name": data.brand
  },
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": data.score ?? 80,
      "bestRating": "100",
      "worstRating": "0"
    },
    "author": {
      "@type": "Organization",
      "name": "What Works Skin"
    }
  }
};
---
<Base title={`${data.brand} ${data.name} — Product review`} description={description} schema={schema}>
  <ProductBrief data={data} />
</Base>
