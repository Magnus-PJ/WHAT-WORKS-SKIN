---
import Base from "@/layouts/Base.astro";
---
<Base title="Not found — What Works Skin">
  <main style="padding: 6rem 2rem; max-width: 48rem; margin: 0 auto; text-align: center;">
    <p style="font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; color: var(--accent); text-transform: uppercase;">404 · not filed</p>
    <h1 style="font-family: var(--font-serif); font-size: clamp(72px, 12vw, 144px); line-height: 0.9; letter-spacing: -0.05em; font-weight: 400; margin: 1.5rem 0;">
      Not <span style="font-family: var(--font-serif-ed); font-style: italic; color: var(--accent);">filed.</span>
    </h1>
    <p style="font-family: var(--font-serif); font-size: 19px; line-height: 1.6; color: var(--ink-soft);">
      That page doesn't exist in the publication. Try the <a href={import.meta.env.BASE_URL} style="color: var(--accent); text-underline-offset: 4px;">home page</a>.
    </p>
  </main>
</Base>
