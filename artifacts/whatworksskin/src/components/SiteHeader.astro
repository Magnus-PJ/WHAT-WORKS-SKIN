---
import Wordmark from "./Wordmark.astro";
import { url, home } from "@/lib/url";

export interface Props {
  active?: string;
}
const { active } = Astro.props;
const nav = ["Ingredients", "Products", "Routines", "Supplements", "Trend Watch", "Concerns", "Editors", "Methodology"];
const linkFor = (label: string) => url(label.toLowerCase().replace(/\s+/g, "-"));
---
<div class="masthead">
  <div class="container">
    <div class="masthead-row">
      <span>What Works Skin — Independent · Evidence-First · Ad-Free</span>
      <span class="hide-md">Issue 014 · 20 April 2026 · Next: 04 May</span>
      <span class="hide-lg">whatworksskin.com</span>
    </div>
  </div>
</div>
<header class="site-header">
  <div class="container">
    <div class="header-row">
      <a href={home} class="brand" aria-label="What Works Skin home">
        <Wordmark size={22} />
      </a>
      <nav id="site-nav" class="nav">
        {nav.map((label) => {
          const isActive = active && label.toLowerCase() === active.toLowerCase();
          return (
            <a
              href={linkFor(label)}
              class:list={["nav-link", isActive && "is-active"]}
            >
              {label}
            </a>
          );
        })}
      </nav>
      <div class="header-actions">
        <a href={url("search")} class="search-btn" aria-label="Search the publication">
          <span>Search</span>
          <kbd>/</kbd>
        </a>
        <button id="menu-toggle" class="menu-toggle" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="site-nav">
          <span class="hamburger-line line-1"></span>
          <span class="hamburger-line line-2"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("menu-toggle");
    const nav = document.getElementById("site-nav");
    if (!toggle || !nav) return;
    
    toggle.addEventListener("click", () => {
      const isOpen = nav.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
      document.body.style.overflow = isOpen ? "hidden" : "";
    });
    
    nav.querySelectorAll(".nav-link").forEach(link => {
      link.addEventListener("click", () => {
        nav.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      });
    });
  });
</script>

<script is:inline define:vars={{ searchHref: url("search") }}>
  // Site-wide `/` shortcut: navigates to the search page from anywhere
  // on the publication. Ignored when the user is typing into an input,
  // textarea, or contenteditable element so it doesn't steal keystrokes
  // mid-form. Already-on-/search? The search input absorbs the `/`
  // because it's an editable element, which is the intended behaviour.
  document.addEventListener("keydown", (e) => {
    if (e.key !== "/") return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const target = e.target;
    if (target instanceof HTMLElement) {
      const tag = target.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return;
      if (target.isContentEditable) return;
    }
    if (window.location.pathname.replace(/\/$/, "") === searchHref.replace(/\/$/, "")) {
      // Already on /search — focus the search input rather than no-op.
      const input = document.getElementById("wws-search-input");
      if (input instanceof HTMLInputElement) {
        e.preventDefault();
        input.focus();
        input.select();
      }
      return;
    }
    e.preventDefault();
    window.location.href = searchHref;
  });
</script>

<style>
  .container {
    margin-inline: auto;
    padding-inline: 32px;
    max-width: 1200px;
  }
  .masthead {
    position: relative;
    z-index: 20;
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  }
  .masthead-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--muted-soft);
    text-transform: uppercase;
  }
  .site-header {
    position: relative;
    z-index: 10;
    border-bottom: 1px solid var(--rule);
    background: color-mix(in srgb, var(--paper) 95%, transparent);
    backdrop-filter: blur(8px);
  }
  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 20px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .nav {
    display: none;
    align-items: center;
    gap: 28px;
    font-family: var(--font-sans);
    font-size: 13.5px;
    color: var(--ink-soft);
  }
  .nav-link {
    text-decoration: none;
    color: var(--ink-soft);
    padding-bottom: 2px;
    transition: color 0.15s ease, border-color 0.15s ease;
    border-bottom: 2px solid transparent;
  }
  .nav-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent-soft);
  }
  .nav-link.is-active {
    color: var(--ink);
    font-weight: 600;
    border-bottom: 2px solid var(--accent);
  }
  .search-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--rule);
    padding: 10px 16px;
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--muted);
    transition: border-color 0.15s ease, color 0.15s ease, background-color 0.15s ease;
  }
  .search-btn:hover {
    border-color: var(--accent);
    color: var(--ink);
    background: var(--paper2);
  }
  .search-btn kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 1px 5px;
    border: 1px solid var(--rule);
    border-radius: 2px;
    transition: border-color 0.15s ease;
  }
  .search-btn:hover kbd {
    border-color: var(--accent-soft);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    border: 0;
    background: transparent;
    cursor: pointer;
    z-index: 100;
  }
  .hamburger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  @media (min-width: 768px) {
    .menu-toggle { display: none; }
    .nav { display: flex; }
  }
  @media (max-width: 767px) {
    .hide-md { display: none; }
    
    .nav {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      left: 0;
      background: var(--paper);
      padding: 120px 32px 40px;
      gap: 24px;
      z-index: 50;
      transform: translateY(-100%);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      overflow-y: auto;
    }
    .nav.is-open {
      transform: translateY(0);
    }
    .nav-link {
      font-size: 24px;
      font-family: var(--font-serif);
      border-bottom: 0;
      padding-bottom: 0;
    }
    .nav-link.is-active {
      border-bottom: 0;
      color: var(--accent);
    }
    
    .menu-toggle[aria-expanded="true"] .line-1 {
      transform: translateY(4px) rotate(45deg);
    }
    .menu-toggle[aria-expanded="true"] .line-2 {
      transform: translateY(-3.5px) rotate(-45deg);
    }
  }
  @media (max-width: 1023px) {
    .hide-lg { display: none; }
  }
</style>
