---
import SiteHeader from "./SiteHeader.astro";
import ThinContentBanner from "./ThinContentBanner.astro";
import SiteFooter from "./SiteFooter.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import PaperEffects from "./PaperEffects.astro";
import AmbientFlask from "./AmbientFlask.astro";
import TierBadge from "./TierBadge.astro";
import MaybeLink from "./MaybeLink.astro";
import { getCollection } from "astro:content";
import { url, home } from "@/lib/url";
import { findProductSlug } from "@/lib/links";
import CitedSourcesBlock from "./CitedSourcesBlock.astro";

type Tier = "A" | "B" | "C" | "D";

export interface Props {
  data: {
    slug: string;
    name: string;
    family: string;
    target: string;
    tier: Tier;
    dose?: string;
    rxOnly?: boolean;
    oneliner: string;
    pageRef?: string;
    filed?: string;
    eyebrow?: string;
    headline?: string;
    dek?: string;
    subheadA?: string;
    subheadB?: string;
    bottom?: string;
    glance?: [string, string][];
    evidence?: {
      // study-table shape (polypodium-style)
      yr?: string; n?: string | number; design?: string; dose?: string; outcome?: string; grade?: string;
      // bar-chart shape (JSX-prop pages)
      c?: string; w?: string; note?: string;
    }[];
    forms?: {
      // shelf-card shape
      brand?: string; name?: string; dose?: string; note?: string; tier?: Tier;
      // f/abs/note shape from JSX-prop pages
      f?: string; abs?: string;
    }[];
    faq?: { q: string; a: string }[];
    citations?: string[];
  };
}
const { data } = Astro.props;
// Two evidence shapes co-exist in the source corpus: an older
// study-table (yr/n/design/dose/outcome/grade) and a newer bar-chart
// shape (c/n/w/note). Render whichever one the JSON carries.
const evidenceIsBars =
  Array.isArray(data.evidence) &&
  data.evidence.length > 0 &&
  data.evidence.every((e) => typeof e.c === "string" && typeof e.w === "string");
// Forms also have two shapes: brand/name/dose vs f/abs/note.
const formsAreFAbs =
  Array.isArray(data.forms) &&
  data.forms.length > 0 &&
  data.forms.every((f) => typeof f.f === "string" && typeof f.abs === "string");
// For shelf-shape `forms`, resolve each card to a product brief slug
// so the card can become a clickable link when a brief exists.
const formProductLinks: (string | undefined)[] =
  data.forms && !formsAreFAbs
    ? await Promise.all(
        data.forms.map((f) => findProductSlug(f.brand, f.name)),
      )
    : [];
// Inbound link-coverage caption — mirrors the catalogue index card's
// "Linked from N concerns" line. Concerns reference supplements via an
// explicit slug on each `supplements[]` entry, so a direct equality
// match is the right resolver here (no fuzzy text to bridge). We
// collect the actual concern entries (not just a count) so the
// "Where it appears" cross-references section below can list them
// and the caption can scroll-anchor into that list.
const concernsForLinkCount = await getCollection("concerns");
const linkedConcerns: { slug: string; name: string }[] = [];
for (const c of concernsForLinkCount) {
  const sups = (c.data.supplements ?? []) as Array<{ slug?: string }>;
  if (sups.some((x) => x?.slug === data.slug)) {
    linkedConcerns.push({ slug: c.data.slug, name: c.data.name });
  }
}
const linkedConcernCount = linkedConcerns.length;
---
<div class="page">
  <ThinContentBanner kind="supplements" slug={data.slug} />
  <SiteHeader active="Supplements" />
  <Breadcrumbs trail={[
    { label: "Home", href: home },
    { label: "Supplements", href: url("supplements") },
    { label: data.name },
  ]} />

  <section class="hero">
    <PaperEffects vignette columns columnsOpacity={0.32} />
    <div class="flask"><AmbientFlask size={520} opacity={0.06} /></div>
    <div class="container">
      <div class="hero-grid">
        <div class="hero-main">
          <div class="hero-eyebrow-row">
            <p class="eyebrow eyebrow-accent">{data.eyebrow ?? `Supplement · ${data.family} · ${data.name}`}</p>
            {data.pageRef && <span class="hero-pageref">{data.pageRef} · BRIEF</span>}
          </div>
          <h1 class="hero-h1">{data.headline ?? data.name}.</h1>
          {(data.subheadA || data.subheadB) ? (
            <p class="hero-subhead-line">
              {data.subheadA && <span class="hero-subhead-a">{data.subheadA}</span>}
              {data.subheadB && <> <span class="hero-subhead-b">{data.subheadB}</span></>}
            </p>
          ) : (
            <p class="hero-tagline-line"><span class="ital">{data.oneliner}</span></p>
          )}
          {data.dek && <p class="hero-lead">{data.dek}</p>}
        </div>
        <aside class="hero-aside">
          <div class="card">
            <div class="card-head"><p class="eyebrow eyebrow-accent">At a glance</p><TierBadge tier={data.tier} size="md" /></div>
            <dl>
              <div class="kv"><dt>Family</dt><dd>{data.family}</dd></div>
              <div class="kv"><dt>Target</dt><dd>{data.target}</dd></div>
              {data.dose && <div class="kv"><dt>Dose</dt><dd>{data.dose}</dd></div>}
              {data.rxOnly && <div class="kv"><dt>Rx</dt><dd>Prescription only</dd></div>}
              {data.filed && <div class="kv"><dt>Filed</dt><dd>{data.filed}</dd></div>}
            </dl>
            <p
              class="bk-caption"
              aria-label={`Linked from ${linkedConcernCount} concerns`}
            >
              <span class="bk-caption-label">Linked from</span>
              {linkedConcernCount > 0 ? (
                <a class="bk-caption-link" href="#linked-concerns">
                  <span class="bk-caption-n on">{linkedConcernCount}</span> {linkedConcernCount === 1 ? "concern" : "concerns"}
                </a>
              ) : (
                <><span class="bk-caption-n">{linkedConcernCount}</span> {linkedConcernCount === 1 ? "concern" : "concerns"}</>
              )}
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="body-col">
      {data.glance && data.glance.length > 0 && (
        <article>
          <p class="folio">— § 01</p>
          <h2 class="h-display">The <span class="ital">brief.</span></h2>
          <dl class="glance">
            {data.glance.map(([k, v]) => (
              <div class="g-kv"><dt>{k}</dt><dd>{v}</dd></div>
            ))}
          </dl>
        </article>
      )}

      {data.evidence && data.evidence.length > 0 && (
        <>
          <div class="asterism"><span class="rule" /><span class="ast">⁂</span><span class="rule" /></div>
          <article>
            <p class="folio">— § 02</p>
            <h2 class="h-display">What the <span class="ital">literature shows.</span></h2>
            {evidenceIsBars ? (
              <div class="ev-bars">
                {data.evidence.map((t) => {
                  const wRaw = typeof t.w === "string" ? t.w.trim() : "";
                  const isPct = /^\d{1,3}(\.\d+)?%$/.test(wRaw);
                  return (
                  <div class="ev-bar-row">
                    <div class="ev-bar-key">
                      <div class="ev-bar-c">{t.c}</div>
                      {t.n && <div class="ev-bar-n">{t.n}</div>}
                    </div>
                    <div class={`ev-bar-track${isPct ? "" : " ev-bar-track-caution"}`}>
                      {isPct && <div class="ev-bar-fill" style={`width:${wRaw}`} />}
                      {t.note && <p class="ev-bar-note">{t.note}</p>}
                    </div>
                    <div class={`ev-bar-pct${isPct ? "" : " ev-bar-pct-caution"}`}>{wRaw}</div>
                  </div>
                  );
                })}
              </div>
            ) : (
              <div class="trials">
                <div class="tr-head"><div>Year</div><div>n</div><div>Design</div><div>Dose</div><div>Outcome</div><div>Grade</div></div>
                {data.evidence.map((t) => (
                  <div class="tr-row">
                    <div>{t.yr}</div>
                    <div>{t.n}</div>
                    <div class="tr-design">{t.design}</div>
                    <div class="tr-dose">{t.dose}</div>
                    <div class="tr-outcome">{t.outcome}</div>
                    <div>{t.grade}</div>
                  </div>
                ))}
              </div>
            )}
          </article>
        </>
      )}

      {data.forms && data.forms.length > 0 && (
        <>
          <div class="asterism"><span class="rule" /><span class="ast">⁂</span><span class="rule" /></div>
          <article>
            <p class="folio">— § 03</p>
            <h2 class="h-display">{formsAreFAbs ? <>Forms and <span class="ital">bioavailability.</span></> : <>On <span class="ital">our shelf.</span></>}</h2>
            <div class={formsAreFAbs ? "form-grid" : "cards"}>
              {data.forms.map((f, idx) => (formsAreFAbs ? (
                <div class="form-card">
                  <h3 class="form-title">{f.f}</h3>
                  {f.abs && <div class="form-abs">Absorption · {f.abs}</div>}
                  {f.note && <p class="form-note">{f.note}</p>}
                </div>
              ) : (() => {
                const slug = formProductLinks[idx];
                return (
                  <MaybeLink
                    href={slug ? url(`products/${slug}`) : undefined}
                    class={`card-cell${slug ? " card-cell-link" : ""}`}
                  >
                    <div class="shelf-head">
                      <span class="shelf-brand">{f.brand}</span>
                      {f.tier && <TierBadge tier={f.tier} />}
                    </div>
                    <div class="shelf-name">{f.name}{slug && <span class="link-arrow" aria-hidden="true"> →</span>}</div>
                    {f.dose && <p class="shelf-dose">{f.dose}</p>}
                    {f.note && <p class="shelf-note">{f.note}</p>}
                  </MaybeLink>
                );
              })()))}
            </div>
          </article>
        </>
      )}

      {linkedConcerns.length > 0 && (
        <>
          <div class="asterism"><span class="rule" /><span class="ast">⁂</span><span class="rule" /></div>
          <article>
            <p class="folio">— Cross-references</p>
            <h2 class="h-display">Where it <span class="ital">appears.</span></h2>
            <div class="backlinks">
              <div class="bk-col" id="linked-concerns">
                <p class="eyebrow eyebrow-accent">Concerns that recommend it</p>
                <ul class="bk-list">
                  {linkedConcerns.map((c) => (
                    <li>
                      <a class="bk-link" href={url(`concerns/${c.slug}`)}>
                        <span class="bk-name">{c.name}</span>
                        <span class="bk-arrow" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        </>
      )}

      {data.bottom && (
        <>
          <div class="asterism"><span class="rule" /><span class="ast">⁂</span><span class="rule" /></div>
          <div class="bottom-line">
            <p class="eyebrow eyebrow-accent">Bottom line</p>
            <p class="bottom-line-body">{data.bottom}</p>
          </div>
        </>
      )}

      {data.faq && data.faq.length > 0 && (
        <>
          <div class="asterism"><span class="rule" /><span class="ast">⁂</span><span class="rule" /></div>
          <article>
            <p class="folio">— § 04</p>
            <h2 class="h-display">Frequently <span class="ital">asked.</span></h2>
            <div class="faq">
              {data.faq.map((f, i) => (
                <details class="faq-item" open={i === 0}>
                  <summary><span class="faq-q">{f.q}</span><span class="faq-chev" aria-hidden="true">⌄</span></summary>
                  <p class="faq-a">{f.a}</p>
                </details>
              ))}
            </div>
          </article>
        </>
      )}
    </div>
  </div>
  <div class="container"><CitedSourcesBlock ids={data.citations} /></div>
  <SiteFooter />
</div>

<style>
  .page { position: relative; background: var(--paper); color: var(--ink); font-family: var(--font-sans); }
  .container { margin-inline: auto; padding-inline: 32px; max-width: 1200px; }
  .eyebrow { margin: 0; font-family: var(--font-sans); font-size: 10.5px; letter-spacing: 0.18em; font-weight: 600; text-transform: uppercase; color: var(--muted); }
  .eyebrow-accent { color: var(--accent); }
  .ital { font-style: italic; color: var(--accent); font-family: var(--font-serif-ed); }
  .folio { margin: 0; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.08em; color: var(--muted-soft); }
  .h-display { margin: 8px 0 0; font-family: var(--font-serif); font-size: 52px; line-height: 1; font-weight: 400; font-variation-settings: "opsz" 144, "SOFT" 30; color: var(--ink); letter-spacing: -0.025em; }
  .asterism { display: flex; align-items: center; justify-content: center; gap: 24px; padding-block: 40px; }
  .asterism .rule { height: 1px; width: 96px; background: var(--rule); display: block; }
  .asterism .ast { font-family: var(--font-serif); font-size: 22px; color: var(--muted); letter-spacing: 0.4em; font-variation-settings: "opsz" 144; }

  .hero { position: relative; z-index: 10; overflow: hidden; border-bottom: 1px solid var(--rule); }
  .flask { position: absolute; right: -64px; top: -64px; z-index: 0; }
  .hero-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 40px; padding-block: 96px; position: relative; }
  .hero-main { grid-column: span 12 / span 12; }
  @media (min-width: 1024px) { .hero-main { grid-column: span 8 / span 8; padding-left: 48px; } }
  .hero-eyebrow-row { display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--rule); padding-bottom: 16px; }
  .hero-pageref { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--muted-soft); }
  .hero-h1 { margin: 40px 0 0; font-family: var(--font-serif); font-size: clamp(56px, 9vw, 110px); line-height: 0.92; letter-spacing: -0.045em; font-weight: 400; color: var(--ink); font-variation-settings: "opsz" 144, "SOFT" 30; }
  .hero-tagline-line { margin: 18px 0 0; font-family: var(--font-serif-ed); font-size: 26px; font-style: italic; color: var(--accent); letter-spacing: -0.02em; }
  .hero-subhead-line { margin: 12px 0 0; font-family: var(--font-serif-ed); font-size: 30px; letter-spacing: -0.02em; line-height: 1.15; }
  .hero-subhead-a { font-style: italic; color: var(--accent); }
  .hero-subhead-b { color: var(--ink-soft); font-family: var(--font-serif); font-style: normal; }
  .hero-lead { margin: 32px 0 0; max-width: 36rem; font-family: var(--font-serif); font-size: 21px; line-height: 1.55; color: var(--ink-soft); }
  .hero-aside { grid-column: span 12 / span 12; }
  @media (min-width: 1024px) { .hero-aside { grid-column: span 4 / span 4; display: flex; align-items: flex-end; } }
  .card { width: 100%; border: 1px solid var(--rule); background: var(--paper); }
  .card-head { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid var(--rule); background: var(--paper2); }
  dl { margin: 0; padding: 0; }
  .kv { padding: 12px 24px; border-bottom: 1px solid var(--rule-soft); }
  .kv:last-child { border-bottom: 0; }
  .kv dt { font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.16em; color: var(--muted-soft); text-transform: uppercase; }
  .kv dd { margin: 4px 0 0; font-family: var(--font-serif); font-size: 14.5px; color: var(--ink); line-height: 1.45; }
  /* link-coverage caption — same mono treatment as the catalogue index card */
  .bk-caption { margin: 0; padding: 14px 24px; border-top: 1px solid var(--rule-soft); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.12em; color: var(--muted-soft); text-transform: uppercase; line-height: 1.4; }
  .bk-caption-label { margin-right: 4px; }
  .bk-caption-n { font-weight: 600; color: var(--muted-soft); margin-right: 2px; }
  .bk-caption-n.on { color: var(--accent); }
  .bk-caption-dot { margin: 0 6px; color: var(--muted-soft); }
  .bk-caption-link { color: inherit; text-decoration: none; border-bottom: 1px dotted transparent; transition: border-color 0.15s ease, color 0.15s ease; }
  .bk-caption-link:hover { border-bottom-color: var(--accent); color: var(--accent); }
  .bk-caption-link:hover .bk-caption-n.on { color: var(--accent); }
  :target { scroll-margin-top: 24px; }

  /* "Where it appears" backlinks list — mirrors the IngredientBrief / ProductBrief pattern */
  .backlinks { margin-top: 36px; display: grid; grid-template-columns: 1fr; gap: 32px; }
  @media (min-width: 768px) { .backlinks { grid-template-columns: 1fr 1fr; gap: 48px; } }
  .bk-col .eyebrow { margin: 0 0 14px; }
  .bk-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--rule); }
  .bk-list li { border-bottom: 1px solid var(--rule-soft); }
  .bk-list li:last-child { border-bottom: 1px solid var(--rule); }
  .bk-link { display: grid; grid-template-columns: 1fr auto; align-items: baseline; gap: 12px; padding: 14px 4px; color: inherit; text-decoration: none; font-family: var(--font-serif); transition: padding 0.15s ease; }
  .bk-link:hover { padding-left: 10px; padding-right: 10px; background: var(--paper2); }
  .bk-link .bk-name { font-size: 17px; color: var(--ink); }
  .bk-link:hover .bk-name { color: var(--accent); }
  .bk-link .bk-arrow { font-family: var(--font-mono); font-size: 12px; color: var(--accent); }

  .body-col { padding-block: 80px; }
  article { margin-block: 32px; }

  .glance { margin-top: 36px; display: grid; grid-template-columns: 1fr; border-top: 1px solid var(--rule); border-left: 1px solid var(--rule); }
  @media (min-width: 768px) { .glance { grid-template-columns: repeat(2, 1fr); } }
  .g-kv { padding: 18px 24px; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--paper); }
  .g-kv dt { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; color: var(--muted-soft); text-transform: uppercase; }
  .g-kv dd { margin: 6px 0 0; font-family: var(--font-serif); font-size: 16px; color: var(--ink); line-height: 1.45; }

  /* evidence bars (c/n/w/note shape) */
  .ev-bars { margin-top: 36px; display: flex; flex-direction: column; gap: 22px; }
  .ev-bar-row { display: grid; grid-template-columns: 1fr; gap: 12px; align-items: start; }
  @media (min-width: 768px) { .ev-bar-row { grid-template-columns: 4fr 7fr 2fr; gap: 28px; } }
  .ev-bar-c { font-family: var(--font-serif); font-size: 18px; line-height: 1.25; color: var(--ink); font-variation-settings: "opsz" 144; }
  .ev-bar-n { margin-top: 6px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--muted-soft); text-transform: uppercase; }
  .ev-bar-track { display: block; }
  .ev-bar-track > .ev-bar-fill { display: block; height: 6px; background: var(--accent); }
  .ev-bar-row .ev-bar-track { background: var(--rule-soft); }
  .ev-bar-note { margin: 12px 0 0; font-family: var(--font-serif); font-size: 14.5px; color: var(--muted); font-style: italic; line-height: 1.55; }
  .ev-bar-pct { font-family: var(--font-serif); font-size: 28px; font-variation-settings: "opsz" 144; color: var(--ink); letter-spacing: -0.02em; }
  @media (min-width: 768px) { .ev-bar-pct { text-align: right; } }
  .ev-bar-track-caution { background: transparent; min-height: 6px; }
  .ev-bar-pct-caution { font-size: 18px; font-style: italic; color: var(--tier-d, #b3261e); letter-spacing: 0; }

  /* form cards (f/abs/note shape) */
  .form-grid { margin-top: 36px; display: grid; grid-template-columns: 1fr; gap: 16px; }
  @media (min-width: 768px) { .form-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .form-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  .form-card { padding: 24px; background: var(--paper); border: 1px solid var(--rule); }
  .form-title { margin: 0; font-family: var(--font-serif); font-size: 22px; line-height: 1.15; color: var(--ink); font-variation-settings: "opsz" 144; font-weight: 400; }
  .form-abs { margin-top: 8px; font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--accent); text-transform: uppercase; }
  .form-note { margin: 16px 0 0; font-family: var(--font-serif); font-size: 14.5px; line-height: 1.6; color: var(--ink-soft); }

  /* bottom-line callout */
  .bottom-line { margin-top: 0; max-width: 48rem; padding: 20px 28px; background: var(--paper); border-left: 4px solid var(--accent); }
  .bottom-line-body { margin: 8px 0 0; font-family: var(--font-serif); font-size: 19px; font-style: italic; color: var(--ink); line-height: 1.55; }

  .trials { margin-top: 36px; border: 1px solid var(--rule); background: var(--paper); overflow-x: auto; }
  .tr-head, .tr-row { display: grid; grid-template-columns: 80px 60px 2fr 2fr 4fr 60px; gap: 16px; padding: 14px 20px; border-bottom: 1px solid var(--rule-soft); align-items: center; min-width: 720px; }
  .tr-head { background: var(--paper2); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; color: var(--muted-soft); text-transform: uppercase; }
  .tr-row:last-child { border-bottom: 0; }
  .tr-row { font-family: var(--font-serif); font-size: 14.5px; color: var(--ink-soft); }
  .tr-design, .tr-outcome { font-style: italic; }
  .ev-srclink { display: inline-block; margin-top: 6px; font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.08em; color: var(--muted); text-transform: uppercase; text-decoration: none; font-style: normal; }
  .ev-srclink:hover { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }

  .cards { margin-top: 36px; display: grid; grid-template-columns: 1fr; border-top: 1px solid var(--rule); border-left: 1px solid var(--rule); }
  @media (min-width: 768px) { .cards { grid-template-columns: repeat(2, 1fr); } }
  .card-cell { padding: 24px; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); background: var(--paper); }
  .card-cell-link { color: inherit; text-decoration: none; transition: background 0.15s ease; display: block; }
  .card-cell-link:hover { background: var(--paper2); }
  .card-cell-link .shelf-name { color: var(--accent); }
  .link-arrow { font-family: var(--font-mono); font-size: 11px; color: var(--accent); margin-left: 4px; }
  .shelf-head { display: flex; align-items: center; justify-content: space-between; }
  .shelf-brand { font-family: var(--font-sans); font-size: 11px; letter-spacing: 0.18em; color: var(--muted); text-transform: uppercase; font-weight: 600; }
  .shelf-name { margin-top: 8px; font-family: var(--font-serif); font-size: 18px; color: var(--ink); }
