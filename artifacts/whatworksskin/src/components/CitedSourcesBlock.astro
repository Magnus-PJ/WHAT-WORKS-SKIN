---
// Renders a small "Cited sources" block at the foot of a brief.
// Each entry links into the /sources catalogue at the matching
// citation anchor. The brief itself is also added to that
// citation's `citedBy` list by `buildCitationIndex` so the link
// is bidirectional.
import { url } from "@/lib/url";
export interface Props {
  ids?: string[];
}
const { ids } = Astro.props;
const list = (ids ?? []).filter((s) => typeof s === "string" && s.trim().length > 0);
---
{list.length > 0 && (
  <section class="cited-sources" aria-label="Cited sources">
    <p class="eyebrow">Cited sources</p>
    <ol class="cs-list">
      {list.map((id, i) => (
        <li class="cs-row">
          <span class="cs-no">№ {String(i + 1).padStart(2, "0")}</span>
          <a class="cs-link" href={url(`sources#${id}`)}>
            <code class="cs-id">{id}</code>
            <span class="cs-arrow">on /sources →</span>
          </a>
        </li>
      ))}
    </ol>
  </section>
)}

<style>
  .cited-sources {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--rule);
  }
  .eyebrow {
    margin: 0 0 16px;
    font-family: var(--font-sans);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
  }
  .cs-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .cs-row { display: flex; align-items: baseline; gap: 12px; }
  .cs-no {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--muted);
    letter-spacing: 0.06em;
    min-width: 44px;
  }
  .cs-link {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
  }
  .cs-link:hover .cs-arrow { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .cs-id {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    background: var(--paper2);
    padding: 2px 8px;
    border: 1px solid var(--rule);
    border-radius: 2px;
  }
  .cs-arrow {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>
