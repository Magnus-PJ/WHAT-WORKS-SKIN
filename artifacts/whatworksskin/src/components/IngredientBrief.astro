                  <li class="mb-overflow">
                    <a class="mb-link" href={url(`ingredients/${m.slug}`)}>
                      <TierBadge tier={m.tier} />
                      <span class="mb-name">{m.name}</span>
                      <span class="mb-arrow" aria-hidden="true">→</span>
                    </a>
                  </li>
                ))}
              </ul>
              {hasMentionedByOverflow && (
                <label for={mentionedByToggleId} class="mb-toggle-btn">
                  <span class="mb-toggle-more">{mentionedByToggleLabel}</span>
                  <span class="mb-toggle-less">Show fewer</span>
                </label>
              )}
            </article>
          </>
        )}

        {hasBacklinks && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— Cross-references</p>
              <h2 class="h-display">Where it <span class="ital">appears.</span></h2>
              <div class="backlinks">
                {backlinks.concerns.length > 0 && (
                  <div class="bk-col" id="linked-concerns">
                    <p class="eyebrow eyebrow-accent">Concerns it treats</p>
                    <ul class="bk-list">
                      {backlinks.concerns.map((c) => (
                        <li>
                          <a class="bk-link" href={url(`concerns/${c.slug}`)}>
                            <span class="bk-name">{c.name}</span>
                            <span class="bk-arrow" aria-hidden="true">→</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
                {backlinks.routines.length > 0 && (
                  <div class="bk-col" id="linked-routines">
                    <p class="eyebrow eyebrow-accent">Routines that use it</p>
                    <ul class="bk-list">
                      {backlinks.routines.map((r) => (
                        <li>
                          <a class="bk-link" href={url(`routines/${r.slug}`)}>
                            <span class="bk-name">{r.title}</span>
                            <span class="bk-sub">{r.sub}{r.stepTitle ? ` · ${r.stepTitle}` : ""}</span>
                            <span class="bk-arrow" aria-hidden="true">→</span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          </>
        )}

        {data.reviewer && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article class="reviewer">
              <p class="folio">— {folio.reviewer}</p>
              <h2 class="h-display">Reviewed <span class="ital">by.</span></h2>
              <div class="reviewer-row">
                <div class="reviewer-card">
                  {data.reviewer.quote && (
                    <p class="reviewer-quote">"{data.reviewer.quote}"</p>
