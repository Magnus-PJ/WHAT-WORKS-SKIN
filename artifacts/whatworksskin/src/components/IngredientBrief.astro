              </p>
              {hasMentionedByOverflow && (
                <input
                  type="checkbox"
                  id={mentionedByToggleId}
                  class="mb-toggle"
                  aria-label={`Show all ${mentionedByTotal} ingredients that mention ${data.name}`}
