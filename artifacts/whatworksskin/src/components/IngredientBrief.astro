---
import { getCollection } from "astro:content";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import PaperEffects from "./PaperEffects.astro";
import AmbientFlask from "./AmbientFlask.astro";
import TierBadge from "./TierBadge.astro";
import MaybeLink from "./MaybeLink.astro";
import { url, home } from "@/lib/url";
import {
  findConcernSlug,
  findIngredientSlug,
  findProductSlug,
  getIngredientBacklinks,
  getIngredientCards,
  getIngredientMentionedBy,
  type IngredientCard,
} from "@/lib/links";
import {
  filterRenderedMentionedBy,
  splitMentionedByForCap,
} from "@/lib/mentioned-by";
import { citationIdForStudy } from "@/lib/citations";
import CitedSourcesBlock from "./CitedSourcesBlock.astro";

type Tier = "A" | "B" | "C" | "D";
type Pair = readonly [string, string];

export interface IngredientBriefData {
  slug: string;
  name: string;
  number: string;
  filed: string;
  eyebrowKicker: string;
  tier: Tier;
  headlineSize?: number;
  chemistry?: string;
  tagline?: { italic: string; rest: string };
  lead: string;
  atGlance: Pair[];
  toc: Pair[];
  whatItIs: { dropCap: string; title: { plain: string; italic: string }; body: string; body2?: string };
  mechanism?: { k: string; b: string }[];
  evidence?: { c: string; n: string; w: string; note: string }[];
  studies?: {
    authors: string;
    journal: string;
    year: number | string;
    pmid: string;
    n?: number | string | null;
    design: string;
    duration: string;
    finding: string;
    grade: Tier;
  }[];
  concentration?: { c: string; v: string; b: string }[];
  byConcern?: { concern: string; range: string; note: string; evidence: string }[];
  howToUse?: { eyebrow: string; body: string }[];
  mistakes?: { t: string; b: string }[];
  myths?: { m: string; t: string }[];
  pairings?: { with: string; verdict: string; note: string; ok: boolean }[];
  products: { brand: string; name: string; tier: Tier; score?: number; price?: string; note: string }[];
  faq: { q: string; a: string }[];
  related?: { tier: Tier; name: string; sub: string }[];
  relatedIngredients?: (string | { slug: string; sub: string })[];
  reviewer?: { name: string; credentials?: string; title: string; quote?: string };
}

export interface Props { data: IngredientBriefData }
const { data } = Astro.props;
const headlineSize = data.headlineSize ?? 124;
const tierAColor = "var(--tier-a)";
const tierDColor = "var(--tier-d)";

// Two layout shapes are supported by the same template:
//   • LEGACY (26 ingredients ported from the original mockup): TOC
//     04 Concentration → 06 Pairings → 07 On our shelf →
//     08 FAQ → 09 Sources/Reviewer (note: the legacy template
//     intentionally skips § 05 because the "Where it earns its
//     tier" TOC entry is decorative, not a rendered section).
//   • EXTENDED (e.g. tretinoin): TOC adds Studies, Concentration
//     by concern, How-to-use, Mistakes, Myths, and Related, and
//     reorders FAQ before Products. Folios in this shape are
//     contiguous 02 → 11 to match the source mockup exactly.
const isExtendedShape = !!(
  data.studies?.length ||
  data.byConcern?.length ||
  data.howToUse?.length ||
  data.mistakes?.length ||
  data.myths?.length ||
  data.related?.length
);
// `relatedIngredients` (slug-based) and the legacy `related` block
// both render the same "Related ingredients" section. The legacy
// shape carries hand-authored `sub` copy; the slug-based shape is
// resolved against the linked brief's metadata at build time.
const relatedSlugCards: IngredientCard[] = data.relatedIngredients
  ? await getIngredientCards(data.relatedIngredients)
  : [];
const hasRelatedSection =
  (data.related?.length ?? 0) > 0 || relatedSlugCards.length > 0;
const folio = {
  whatItIs: "§ 01",
  mechanism: "§ 02",
  evidence: "§ 03",
  studies: "§ 03",
  concentration: "§ 04",
  byConcern: "§ 04",
  howToUse: "§ 05",
  mistakes: "§ 06",
  myths: "§ 07",
  pairings: "§ 06",
  faq: "§ 08",
  products: isExtendedShape ? "§ 09" : "§ 07",
  related: isExtendedShape ? "§ 10" : "§ 09",
  reviewer: isExtendedShape
    ? "§ 11"
    : hasRelatedSection
      ? "§ 10"
      : "§ 09",
} as const;
// Resolve every cross-reference once per render. The `products`
// shelf links to product reviews; `byConcern` rows link to the
// concern brief; pairings + related ingredients link to other
// ingredient briefs. Backlinks lead readers to concerns and
// routines that reference this ingredient elsewhere.
const productLinks: (string | undefined)[] = await Promise.all(
  data.products.map((p) => findProductSlug(p.brand, p.name)),
);
const byConcernLinks: (string | undefined)[] = data.byConcern
  ? await Promise.all(data.byConcern.map((row) => findConcernSlug(row.concern)))
  : [];
const pairingLinks: (string | undefined)[] = data.pairings
  ? await Promise.all(data.pairings.map((p) => findIngredientSlug(p.with)))
  : [];
const relatedLinks: (string | undefined)[] = data.related
  ? await Promise.all(data.related.map((r) => findIngredientSlug(r.name)))
  : [];
const backlinks = await getIngredientBacklinks(data.slug);
const hasBacklinks =
  backlinks.concerns.length > 0 || backlinks.routines.length > 0;
// "Mentioned by" surfaces the inverse `relatedIngredients` graph so
// readers landing on a hub ingredient can see the long tail of other
// briefs that name-check it as a daily partner — even when those
// pairings are intentional one-ways (the curated grid only has 4
// reserved slots). We drop any entry that's already on the curated
// grid above so the section reads as additive, not duplicative.
const renderedRelatedSlugs = new Set<string>(
  relatedSlugCards.length > 0
    ? relatedSlugCards.map((c) => c.slug)
    : relatedLinks.filter((s): s is string => Boolean(s)),
);
const mentionedBy = filterRenderedMentionedBy(
  await getIngredientMentionedBy(data.slug),
  renderedRelatedSlugs,
);
const hasMentionedBy = mentionedBy.length > 0;
// Cap the rendered Mentioned-by list so hub ingredients (niacinamide,
// salicylic-acid, …) don't dwarf the curated grid above and crowd
// out the back-link "Where it appears" panel below as more briefs
// ship. Briefs at or under the cap render unchanged — no toggle is
// emitted. Above the cap, the overflow is hidden behind a CSS-only
// "Show all N" disclosure (no JS needed). The cap + split lives in
// `splitMentionedByForCap` (in `src/lib/mentioned-by.ts`) so the
// renderer and `scripts/test-mentioned-by-cap.ts` exercise the same
// code path — a future tweak to the cap or the overflow shape gets
// caught by the contract test instead of silently regressing.
const {
  visible: mentionedByVisible,
  overflow: mentionedByOverflow,
  hasOverflow: hasMentionedByOverflow,
  total: mentionedByTotal,
  toggleLabel: mentionedByToggleLabel,
} = splitMentionedByForCap(mentionedBy);
const mentionedByToggleId = `mb-toggle-${data.slug}`;

// Recommendation engine for "Read Next"
const allIngredients = await getCollection("ingredients");
const otherIngredients = allIngredients.filter(ing => ing.data.slug !== data.slug);

// 1. Pairing partner
const bestPairing = data.pairings?.find((p) => p.ok);
const pairingTarget = bestPairing
  ? otherIngredients.find(ing => ing.data.name.toLowerCase() === bestPairing.with.toLowerCase())
  : null;

// 2. Featured routine
const featuredRoutine = backlinks.routines[0];

// 3. Alternative/Related
const sameTierIngredients = otherIngredients.filter(ing => ing.data.tier === data.tier);
const altIngredient = sameTierIngredients.length > 0
  ? sameTierIngredients[Math.abs(data.slug.charCodeAt(0)) % sameTierIngredients.length]
  : otherIngredients[0];
---
<div class="page">
  <SiteHeader active="Ingredients" />
  <Breadcrumbs trail={[
    { label: "Home", href: home },
    { label: "Ingredients", href: url("ingredients") },
    { label: data.name },
  ]} />

  <!-- HERO -->
  <section class="hero">
    <PaperEffects vignette columns columnsOpacity={0.32} />
    <div class="flask"><AmbientFlask size={560} opacity={0.06} /></div>

    <div class="container">
      <div class="hero-grid">
        <div class="hero-rail">
          <span>INGREDIENT · {data.number}</span>
          <span class="rail-tick" />
          <span>FILED · {data.filed}</span>
        </div>

        <div class="hero-main">
          <div class="hero-eyebrow-row">
            <p class="eyebrow eyebrow-accent">{data.eyebrowKicker}</p>
            <span class="hero-pageref">P. {data.number.split(" ")[0]} · BRIEF</span>
          </div>

          <h1 class="hero-h1" style={`font-size:${headlineSize}px`}>
            {data.name}.
          </h1>
          {data.tagline && (
            <div class="hero-tagline">
              <span class="ital">{data.tagline.italic}</span>
              {data.tagline.rest && (
                <span class="hero-tagline-rest"> {data.tagline.rest}</span>
              )}
            </div>
          )}
          {data.chemistry && (
            <p class="hero-chemistry" set:html={data.chemistry} />
          )}

          <p class="hero-lead">{data.lead}</p>

          <div class="hero-cta">
            <button type="button" class="btn-primary">Read the brief →</button>
            <button type="button" class="btn-ghost">Save</button>
            <button type="button" class="btn-ghost">Share</button>
          </div>
        </div>

        <aside class="hero-aside">
          <div class="card">
            <div class="card-head">
              <p class="eyebrow eyebrow-accent">At a glance</p>
              <TierBadge tier={data.tier} size="md" />
            </div>
            <dl>
              {data.atGlance.map(([k, v]) => (
                <div class="kv">
                  <dt>{k}</dt>
                  <dd>{v}</dd>
                </div>
              ))}
            </dl>
            <p
              class="bk-caption"
              aria-label={`Used in ${backlinks.concerns.length} concerns and ${backlinks.routines.length} routines`}
            >
              <span class="bk-caption-label">Used in</span>
              {backlinks.concerns.length > 0 ? (
                <a class="bk-caption-link" href="#linked-concerns">
                  <span class="bk-caption-n on">{backlinks.concerns.length}</span> concerns
                </a>
              ) : (
                <><span class="bk-caption-n">{backlinks.concerns.length}</span> concerns</>
              )}
              <span class="bk-caption-dot" aria-hidden="true">·</span>
              {backlinks.routines.length > 0 ? (
                <a class="bk-caption-link" href="#linked-routines">
                  <span class="bk-caption-n on">{backlinks.routines.length}</span> routines
                </a>
              ) : (
                <><span class="bk-caption-n">{backlinks.routines.length}</span> routines</>
              )}
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- BODY -->
  <div class="container">
    <div class="body-grid">
      <aside class="toc">
        <div class="toc-sticky">
          <p class="eyebrow">Inside this brief</p>
          <ol>
            {data.toc.map(([n, t]) => (
              <li>
                <span class="toc-n">{n}</span>
                <span class="toc-t">{t}</span>
              </li>
            ))}
          </ol>
        </div>
      </aside>

      <div class="body-col">
        <article>
          <p class="folio">— {folio.whatItIs}</p>
          <h2 class="h-display">
            {data.whatItIs.title.plain} <span class="ital">{data.whatItIs.title.italic}</span>
          </h2>
          <p class="body-lead">
            <span class="dropcap">{data.whatItIs.dropCap}</span>{data.whatItIs.body}
          </p>
          {data.whatItIs.body2 && <p class="body-lead">{data.whatItIs.body2}</p>}
        </article>

        {data.mechanism && data.mechanism.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.mechanism}</p>
              <h2 class="h-display">Mechanism, <span class="ital">plainly.</span></h2>
              <div class="cards" style={`--cols:${Math.min(data.mechanism.length, 3)}`}>
                {data.mechanism.map((x) => (
                  <div class="card-cell">
                    <p class="eyebrow eyebrow-accent">{x.k}</p>
                    <p class="card-body">{x.b}</p>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.evidence && data.evidence.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.evidence}</p>
              <h2 class="h-display">The <span class="ital">evidence.</span></h2>
              <div class="evidence-list">
                {data.evidence.map((e) => (
                  <div class="evidence-row">
                    <div class="ev-claim">
                      <div class="ev-c">{e.c}</div>
                      <div class="ev-n">{e.n}</div>
                    </div>
                    <div class="ev-bar-wrap">
                      <div class="ev-bar"><div class="ev-bar-fill" style={`width:${e.w}`} /></div>
                      <p class="ev-note">{e.note}</p>
                    </div>
                    <div class="ev-pct">{e.w}</div>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.studies && data.studies.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.studies}</p>
              <h2 class="h-display">The <span class="ital">evidence.</span></h2>
              <p class="body-lead">Selected primary literature. Each citation links to PubMed. We weight RCTs and large meta-analyses heaviest; case reports do not move our grade.</p>
              <div class="studies">
                {data.studies.map((s, i) => (
                  <div class="study-row">
                    <div class="study-meta">
                      <div class="study-no">STUDY № {String(i + 1).padStart(2, "0")}</div>
                      <div class="study-authors">{s.authors}</div>
                      <div class="study-journal">{s.journal} · {s.year}</div>
                      <a class="study-pmid" href={`https://pubmed.ncbi.nlm.nih.gov/${s.pmid}/`}>PMID {s.pmid} ↗</a>
                      <a class="study-srclink" href={url(`sources#${citationIdForStudy(s)}`)}>On /sources →</a>
                    </div>
                    <div class="study-body">
                      <p class="study-finding">{s.finding}</p>
                      <div class="study-bits">
                        <span>Design · {s.design}</span>
                        {s.n != null && s.n !== "" && <span>n = {s.n}</span>}
                        <span>Duration · {s.duration}</span>
                      </div>
                    </div>
                    <div class="study-grade">
                      <TierBadge tier={s.grade} />
                    </div>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.concentration && data.concentration.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.concentration}</p>
              <h2 class="h-display">Concentration <span class="ital">& vehicle.</span></h2>
              <div class="cards" style={`--cols:${Math.min(data.concentration.length, 4)}`}>
                {data.concentration.map((x) => (
                  <div class="card-cell">
                    <div class="conc-c">{x.c}</div>
                    <div class="conc-v">{x.v}</div>
                    <p class="conc-b">{x.b}</p>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.byConcern && data.byConcern.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.byConcern}</p>
              <h2 class="h-display">Concentration <span class="ital">by concern.</span></h2>
              <div class="byconcern">
                <div class="byc-head">
                  <div>Concern</div>
                  <div>Evidence-grade range</div>
                  <div>Note</div>
                  <div class="byc-grade-h">Grade</div>
                </div>
                {data.byConcern.map((row, idx) => {
                  const slug = byConcernLinks[idx];
                  return (
                    <MaybeLink
                      href={slug ? url(`concerns/${slug}`) : undefined}
                      class={`byc-row${slug ? " byc-row-link" : ""}`}
                    >
                      <div class="byc-concern">{row.concern}{slug && <span class="link-arrow" aria-hidden="true"> →</span>}</div>
                      <div class="byc-range">{row.range}</div>
                      <div class="byc-note">{row.note}</div>
                      <div class="byc-grade"><span>{row.evidence}</span></div>
                    </MaybeLink>
                  );
                })}
              </div>
            </article>
          </>
        )}

        {data.howToUse && data.howToUse.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.howToUse}</p>
              <h2 class="h-display">How to <span class="ital">use.</span></h2>
              <div class="howto">
                {data.howToUse.map((b) => (
                  <div class="howto-cell">
                    <p class="eyebrow eyebrow-accent">{b.eyebrow}</p>
                    <p class="howto-body">{b.body}</p>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.mistakes && data.mistakes.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.mistakes}</p>
              <h2 class="h-display">Common <span class="ital">mistakes.</span></h2>
              <div class="mistakes">
                {data.mistakes.map((m, i) => (
                  <div class="mistake-row">
                    <div class="mistake-no">{String(i + 1).padStart(2, "0")}</div>
                    <div class="mistake-body">
                      <h3 class="mistake-t">{m.t}</h3>
                      <p class="mistake-b">{m.b}</p>
                    </div>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.myths && data.myths.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.myths}</p>
              <h2 class="h-display">Myths vs <span class="ital">truth.</span></h2>
              <div class="myths">
                {data.myths.map((m) => (
                  <div class="myth-card">
                    <div class="myth-head myth-head-myth">MYTH</div>
                    <p class="myth-quote">"{m.m}"</p>
                    <div class="myth-head myth-head-truth">TRUTH</div>
                    <p class="myth-truth">{m.t}</p>
                  </div>
                ))}
              </div>
            </article>
          </>
        )}

        {data.pairings && data.pairings.length > 0 && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.pairings}</p>
              <h2 class="h-display">Pairings <span class="ital">& conflicts.</span></h2>
              <div class="pairings">
                {data.pairings.map((p, i) => {
                  const slug = pairingLinks[i];
                  return (
                    <MaybeLink
                      href={slug ? url(`ingredients/${slug}`) : undefined}
                      class={`pair-row${slug ? " pair-row-link" : ""}`}
                      style={`background:${i % 2 ? "var(--paper2)" : "var(--paper)"}`}
                    >
                      <div class="pair-with">{p.with}{slug && <span class="link-arrow" aria-hidden="true"> →</span>}</div>
                      <div class="pair-verdict" style={`color:${p.ok ? tierAColor : tierDColor}`}>{p.verdict}</div>
                      <div class="pair-note">{p.note}</div>
                    </MaybeLink>
                  );
                })}
              </div>
            </article>
          </>
        )}

        {isExtendedShape && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.faq}</p>
              <h2 class="h-display">Frequently <span class="ital">asked.</span></h2>
              <div class="faq">
                {data.faq.map((f, i) => (
                  <details class="faq-item" open={i === 0}>
                    <summary>
                      <span class="faq-q">{f.q}</span>
                      <span class="faq-chev" aria-hidden="true">⌄</span>
                    </summary>
                    <p class="faq-a">{f.a}</p>
                  </details>
                ))}
              </div>
            </article>
          </>
        )}

        <div class="asterism">
          <span class="rule" /><span class="ast">⁂</span><span class="rule" />
        </div>

        <article>
          <p class="folio">— {folio.products}</p>
          <h2 class="h-display">On <span class="ital">our shelf.</span></h2>
          <div class="cards" style="--cols:2">
            {data.products.map((p, idx) => {
              const slug = productLinks[idx];
              return (
                <MaybeLink
                  href={slug ? url(`products/${slug}`) : undefined}
                  class={`card-cell shelf-cell${slug ? " shelf-cell-link" : ""}`}
                >
                  <div class="shelf-head">
                    <span class="shelf-brand">{p.brand}</span>
                    <TierBadge tier={p.tier} />
                  </div>
                  <div class="shelf-name">{p.name}{slug && <span class="link-arrow" aria-hidden="true"> →</span>}</div>
                  <p class="shelf-note">{p.note}</p>
                  <div class="shelf-foot">
                    {p.score != null ? (
                      <span class="shelf-score">{p.score}<span class="shelf-score-max">⁄100</span></span>
                    ) : p.price ? (
                      <span class="shelf-score">{p.price}</span>
                    ) : (
                      <span class="shelf-score">—</span>
                    )}
                    <span class="shelf-cta">{slug ? "Read review →" : "Not yet reviewed"}</span>
                  </div>
                </MaybeLink>
              );
            })}
          </div>
        </article>

        {isExtendedShape && hasRelatedSection && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
            <article>
              <p class="folio">— {folio.related}</p>
              <h2 class="h-display">Related <span class="ital">ingredients.</span></h2>
              {relatedSlugCards.length > 0 ? (
                <div class="related" style={`--cols:${Math.min(relatedSlugCards.length, 4)}`}>
                  {relatedSlugCards.map((r) => (
                    <MaybeLink
                      href={url(`ingredients/${r.slug}`)}
                      class="related-cell related-cell-link"
                    >
                      <TierBadge tier={r.tier} />
                      <h3 class="related-name">{r.name}<span class="link-arrow" aria-hidden="true"> →</span></h3>
                      {r.sub && <p class="related-sub">{r.sub}</p>}
                    </MaybeLink>
                  ))}
                </div>
              ) : (
                <div class="related" style={`--cols:${Math.min(data.related!.length, 4)}`}>
                  {data.related!.map((r, idx) => {
                    const slug = relatedLinks[idx];
                    return (
                      <MaybeLink
                        href={slug ? url(`ingredients/${slug}`) : undefined}
                        class={`related-cell${slug ? " related-cell-link" : ""}`}
                      >
                        <TierBadge tier={r.tier} />
                        <h3 class="related-name">{r.name}{slug && <span class="link-arrow" aria-hidden="true"> →</span>}</h3>
                        <p class="related-sub">{r.sub}</p>
                      </MaybeLink>
                    );
                  })}
                </div>
              )}
            </article>
          </>
        )}

        {!isExtendedShape && (
          <>
            <div class="asterism">
              <span class="rule" /><span class="ast">⁂</span><span class="rule" />
            </div>
