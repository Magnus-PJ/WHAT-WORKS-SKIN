args = "pnpm --filter @workspace/whatworksskin run validate:ingredient-shorthand"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-server:test"
author = "agent"

[[workflows.workflow.tasks]]
