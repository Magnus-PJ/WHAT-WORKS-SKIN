modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "matchers"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:matchers"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:related-ingredients-symmetry"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:ingredient-shorthand"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-server:test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:concern-shorthand"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-backlinks"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-mentioned-by"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-related-ingredients"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-product-resolver"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-cross-link-coverage"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:link-coverage-parity"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-catalogue-paired-badge"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-cross-link-coverage-report"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-search-index"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:validate-thin-content"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:validate-transparency-meta"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-mentioned-by-cap"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "whatworksskin:test-search-url-sync"

[[workflows.workflow]]
name = "matchers"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mockup-sandbox run validate:matchers"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "whatworksskin:matchers"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/whatworksskin run report:cross-links"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "whatworksskin:related-ingredients-symmetry"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/whatworksskin run validate:related-ingredients-symmetry"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "whatworksskin:ingredient-shorthand"
author = "agent"

[[workflows.workflow.tasks]]
